#: tapojarvi-preorder.php:219 tapojarvi-preorder.php:226
msgid "Haluatko varmasti jatkaa?"
msgstr "Haluatko varmasti jatkaa?"

#: tapojarvi-preorder.php:218
msgid ""
"Jos haluat kerätä tilauksen yhteistilaukseen ja lähettää myöhemmin muiden "
"tilausten kanssa, sulje tämä ikkuna ja aktivoi “Lisää tämä tilaus työmaan "
"yhteistilaukseen”."
msgstr ""
"Jos haluat kerätä tilauksen yhteistilaukseen ja lähettää myöhemmin muiden "
"tilausten kanssa, sulje tämä ikkuna ja aktivoi “Lisää tämä tilaus työmaan "
"yhteistilaukseen”."

#: tapojarvi-preorder.php:225
msgid ""
"Keräyslista on tarkoitettu vaatekokojen ja mallien keräämiseen "
"yhteistilausta varten. Jos haluat tilata turvallisuusmateriaaleja tai "
"laatikkotavaroita suoraan toimittajalta, sulje tämä ikkuna ja poista edellä "
"mainittu valinta."
msgstr ""
"Keräyslista on tarkoitettu vaatekokojen ja mallien keräämiseen "
"yhteistilausta varten. Jos haluat tilata turvallisuusmateriaaleja tai "
"laatikkotavaroita suoraan toimittajalta, sulje tämä ikkuna ja poista edellä "
"mainittu valinta."

#: tapojarvi-preorder.php:228
msgid "Kyllä, jatka"
msgstr "Kyllä, jatka"

#. Description of the plugin
msgid ""
"Lisää kassalle tilausten hallitsijalle painikkeen, jolla voi valita, meneekö "
"tilaus työmaatilaukset sivulle vai toimittajalle."
msgstr ""
"Lisää kassalle tilausten hallitsijalle painikkeen, jolla voi valita, meneekö "
"tilaus työmaatilaukset-sivulle vai toimittajalle."

#: tapojarvi-preorder.php:72
msgid "Lisää tämä tilaus työmaan yhteistilaukseen"
msgstr "Lisää tämä tilaus työmaan yhteistilaukseen"

